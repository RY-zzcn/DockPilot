# syntax=docker/dockerfile:1.7

FROM --platform=$BUILDPLATFORM golang:1.23-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download
COPY . .
ARG TARGETOS
ARG TARGETARCH
ARG TARGETVARIANT
ARG VERSION=0.2.24
ARG COMMIT=dev
ARG BUILD_DATE=unknown
RUN --mount=type=cache,target=/root/.cache/go-build set -eux; \
    case "${TARGETARCH}/${TARGETVARIANT}" in \
      arm/v6) GOARM=6 ;; \
      arm/v7) GOARM=7 ;; \
      *) GOARM= ;; \
    esac; \
    CGO_ENABLED=0 GOOS="${TARGETOS}" GOARCH="${TARGETARCH}" GOARM="${GOARM}" go build -mod=mod \
      -ldflags="-s -w -X github.com/dockpilot/dockpilot/internal/version.Version=${VERSION} -X github.com/dockpilot/dockpilot/internal/version.Commit=${COMMIT} -X github.com/dockpilot/dockpilot/internal/version.BuildDate=${BUILD_DATE}" \
      -o /out/dockpilot-agent ./cmd/agent

FROM alpine:3.21
RUN apk add --no-cache ca-certificates docker-cli docker-cli-compose tzdata
WORKDIR /app
COPY --from=build /out/dockpilot-agent /app/dockpilot-agent
ENV DOCKPILOT_STATE_PATH=/data/agent.json
ENV DOCKPILOT_INSTALL_MODE=docker
ENV DOCKPILOT_RELEASE_REPO=RY-zzcn/DockPilot
ENV DOCKPILOT_AGENT_IMAGE=ghcr.io/ry-zzcn/dockpilot-agent
ENV TZ=Asia/Shanghai
VOLUME ["/data"]
ENTRYPOINT ["/app/dockpilot-agent"]
